            "mimeType": "application/json",
            "text": "{\"query\": \"fragment CartFragment on CartType {\\n  id\\n  storeId\\n  isAnonymous\\n  hasPhysicalProducts\\n  customerId\\n  itemsCount\\n  itemsQuantity\\n  total {\\n    ...MoneyFragment\\n  }\\n  subTotal {\\n    ...MoneyFragment\\n  }\\n  subTotalDiscount {\\n    ...MoneyFragment\\n  }\\n  shippingTotal {\\n    ...MoneyFragment\\n  }\\n  items {\\n    ...LineItemFragment\\n  }\\n  payments {\\n    ...PaymentFragment\\n  }\\n  shipments {\\n    ...ShipmentFragment\\n  }\\n  coupons {\\n    ...CouponFragment\\n  }\\n  gifts {\\n    ...GiftItemFragment\\n  }\\n  addresses {\\n    ...CartAddressFragment\\n  }\\n  validationErrors {\\n    errorCode\\n    errorMessage\\n    errorParameters {\\n      key\\n      value\\n    }\\n    objectType\\n    objectId\\n  }\\n}\\n\\nfragment GiftItemFragment on GiftItemType {\\n  id\\n  quantity\\n  productId\\n  name\\n  lineItemId\\n}\\n\\nfragment CouponFragment on CouponType {\\n  code\\n  isAppliedSuccessfully\\n}\\n\\nfragment CartAddressFragment on CartAddressType {\\n  id\\n  key\\n  city\\n  countryCode\\n  countryName\\n  email\\n  firstName\\n  middleName\\n  lastName\\n  line1\\n  line2\\n  name\\n  organization\\n  phone\\n  postalCode\\n  regionId\\n  regionName\\n  zip\\n  outerId\\n  description\\n  addressType\\n}\\n\\nfragment MoneyFragment on MoneyType {\\n  amount\\n  formattedAmount\\n}\\n\\nfragment LineItemFragment on LineItemType {\\n  id\\n  sku\\n  productId\\n  name\\n  quantity\\n  listPrice {\\n    ...MoneyFragment\\n  }\\n  salePrice {\\n    ...MoneyFragment\\n  }\\n  placedPrice {\\n    ...MoneyFragment\\n  }\\n  extendedPrice {\\n    ...MoneyFragment\\n  }\\n  discountAmount {\\n    ...MoneyFragment\\n  }\\n  selectedForCheckout\\n}\\n\\nfragment PaymentFragment on PaymentType {\\n  id\\n  outerId\\n  paymentGatewayCode\\n  currency {\\n    ...CurrencyFragment\\n  }\\n  total {\\n    ...MoneyFragment\\n  }\\n  billingAddress {\\n    ...CartAddressFragment\\n  }\\n}\\n\\nfrag